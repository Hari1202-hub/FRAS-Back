    {
      "name": "External App",
      "description": "Separate auth flow for machine-to-machine integrations (e.g. Python face-recognition service).\n\n1. Admin creates a client via 'Create App Client' (uses main JWT).\n2. External app calls 'Get App Token' with client_id + client_secret.\n3. Token is auto-saved to {{app_token}}.\n4. Use {{app_token}} for the App Vectors requests.",
      "item": [

        {
          "name": "App Auth",
          "item": [

            {
              "name": "Get App Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var res = pm.response.json();",
                      "if (res.data && res.data.access_token) {",
                      "    pm.collectionVariables.set('app_token', res.data.access_token);",
                      "    console.log('App token saved:', res.data.access_token);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"client_id\": \"python-face-service\",\n  \"client_secret\": \"your-raw-client-secret-here\",\n  \"ttl_hours\": 24\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{base_url}}/api/v2/app/auth/token",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "auth", "token"]
                },
                "description": "Exchange client_id + client_secret for a time-limited Bearer token.\nToken is auto-saved to {{app_token}}.\nttl_hours is optional (default 24, max 168)."
              }
            }

          ]
        },

        {
          "name": "App Vectors",
          "item": [

            {
              "name": "Get All Vectors",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [{ "key": "token", "value": "{{app_token}}", "type": "string" }]
                },
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/v2/app/vectors?since=2026-01-01&per_page=100&page=1",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "vectors"],
                  "query": [
                    { "key": "since",    "value": "2026-01-01", "description": "Y-m-d — only return vectors updated on/after this date" },
                    { "key": "per_page", "value": "100",        "description": "Records per page (max 500)" },
                    { "key": "page",     "value": "1" },
                    { "key": "no_cache", "value": "0",          "description": "Set to 1 to skip the 30-min cache", "disabled": true }
                  ]
                },
                "description": "Returns staff_guid, staff_id (emp_id), name, image_url, vector, vectors for every enrolled staff member.\nShares the same cache as the internal /vectors endpoint — busted automatically by POST /vectors/invalidate."
              }
            },

            {
              "name": "Get Vector by Staff ID",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [{ "key": "token", "value": "{{app_token}}", "type": "string" }]
                },
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/v2/app/vectors/EMP001",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "vectors", "EMP001"]
                },
                "description": "Route param can be emp_id (e.g. EMP001) or the staff GUID.\nReturns 404 if the staff member has no face enrolled."
              }
            }

          ]
        },

        {
          "name": "App Client Management",
          "description": "Admin-only endpoints (require main JWT Bearer token, not app token).",
          "item": [

            {
              "name": "List App Clients",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/v2/app/clients",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "clients"]
                },
                "description": "Returns all registered external app clients with active-token status and last-used timestamp."
              }
            },

            {
              "name": "Create App Client",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var res = pm.response.json();",
                      "if (res.data && res.data.uuid) {",
                      "    pm.collectionVariables.set('app_uuid', res.data.uuid);",
                      "    console.log('Save this client_secret NOW — it will not be shown again:', res.data.client_secret);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Python Face Service\",\n  \"client_id\": \"python-face-service\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{base_url}}/api/v2/app/clients",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "clients"]
                },
                "description": "Creates a new app client and returns the raw client_secret ONCE.\nSave it immediately — it is hashed on the server and cannot be retrieved again.\nThe client UUID is auto-saved to {{app_uuid}}."
              }
            },

            {
              "name": "Update App Client",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Python Face Service v2\",\n  \"is_active\": true\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{base_url}}/api/v2/app/clients/{{app_uuid}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "clients", "{{app_uuid}}"]
                }
              }
            },

            {
              "name": "Rotate Client Secret",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/v2/app/clients/{{app_uuid}}/rotate-secret",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "clients", "{{app_uuid}}", "rotate-secret"]
                },
                "description": "Generates a new client_secret and immediately revokes the current access token.\nReturns the new raw secret ONCE — save it now."
              }
            },

            {
              "name": "Delete App Client",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/v2/app/clients/{{app_uuid}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v2", "app", "clients", "{{app_uuid}}"]
                },
                "description": "Permanently deletes the app client. Any outstanding tokens are immediately invalid."
              }
            }

          ]
        }

      ]
    }

  ]
}
